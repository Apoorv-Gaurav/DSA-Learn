class Solution {
    public int lengthOfLongestSubstring(String s) {
        int mx = 0;
        HashMap<Character, Integer> hm = new HashMap<>();
        int left = 0;
        int right = 0;
        for(;right<s.length(); right++){
            Character ch = s.charAt(right);
            if(hm.containsKey(ch) && hm.get(ch)>=left){
                left = hm.get(ch)+1;
            }
            mx= Math.max(mx, right-left+1);
            hm.put(ch,right);
        }
        return mx;
    }
}
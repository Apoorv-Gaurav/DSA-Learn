class Solution {
    public int[] rearrangeArray(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];
        int posI = 0, negI = 1;

        for(int i = 0; i<n; i++){
            if(nums[i]>0){
                ans[posI] = nums[i];
                posI = posI+2;
            }
            else{
                ans[negI] = nums[i];
                negI = negI + 2;
            }
        }
        return ans;
    }
}
class Solution {
    public int numOfSubarrays(int[] nums, int k, int threshold) {
        int windowSum = 0;
        for(int i = 0; i < k ; i++){
            windowSum += nums[i];
        }
        int c = 0;
        if(windowSum/k >= threshold) c++;

        for(int i = k; i<nums.length ; i++){
            windowSum += nums[i] - nums[i-k];
            if(windowSum/k >= threshold){
                c++;
            }    
        }
        return c;
    }
}